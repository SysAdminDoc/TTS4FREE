{
  "name": "bettertts",
  "private": true,
  "version": "0.17.0",
  "description": "Private local text-to-speech studio for web and Windows.",
  "author": "SysAdminDoc <matt_parker@outlook.com>",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "npm run clean && npm run typecheck && vite build",
    "test": "vitest run",
    "lint": "oxlint",
    "smoke": "node scripts/smoke.mjs",
    "license:runtime": "node scripts/check-runtime-licenses.mjs",
    "preview": "vite preview",
    "deploy": "node scripts/deploy.mjs",
    "sync:kokoro": "node scripts/sync-kokoro-assets.mjs",
    "sync:piper": "node scripts/sync-piper-assets.mjs",
    "desktop:dev": "cross-env BETTERTTS_TARGET=electron BETTERTTS_DEV_URL=http://localhost:5174/ concurrently -k -n vite,electron \"vite --port 5174 --strictPort\" \"node scripts/build-electron.mjs --dev && wait-on http://localhost:5174/ && node scripts/run-electron.mjs\"",
    "desktop:build": "cross-env BETTERTTS_TARGET=electron npm run build && node scripts/build-electron.mjs",
    "desktop:smoke": "npm run desktop:build && node scripts/run-electron.mjs --smoke",
    "desktop:dist": "npm run desktop:build && electron-builder --win --config electron-builder.yml",
    "desktop:probe-ort": "node scripts/probe-native-ort.mjs",
    "desktop:probe-host": "node scripts/build-electron.mjs && node scripts/probe-native-host.mjs"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@huggingface/transformers": "^4.2.0",
    "@mozilla/readability": "^0.6.0",
    "ephone": "^1.0.2",
    "fflate": "^0.8.3",
    "kitten-tts-webgpu": "^0.1.1",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^1.23.0",
    "onnxruntime-node": "^1.27.0",
    "onnxruntime-web": "^1.27.0",
    "pdfjs-dist": "^6.1.200",
    "phonemizer": "^1.2.1",
    "piper-plus": "^0.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "signalsmith-stretch": "^1.3.2"
  },
  "overrides": {
    "@huggingface/transformers": "$@huggingface/transformers"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  }
}
