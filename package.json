{
  "name": "bettertts",
  "private": true,
  "version": "0.10.0",
  "type": "module",
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "npm run clean && npm run typecheck && vite build",
    "test": "vitest run",
    "lint": "oxlint",
    "preview": "vite preview",
    "deploy": "node scripts/deploy.mjs",
    "sync:kokoro": "node scripts/sync-kokoro-assets.mjs"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@huggingface/transformers": "^3.8.1",
    "@mozilla/readability": "^0.6.0",
    "fflate": "^0.8.3",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "signalsmith-stretch": "^1.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
